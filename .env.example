# Server-only PostgreSQL/Neon connection string. Do not commit a real value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"

# Prisma tooling only. Required for local `prisma migrate dev`; never used by
# the running application or `prisma migrate deploy`. Keep it separate from
# the runtime/production database.
SHADOW_DATABASE_URL=""

# Server-only NextAuth v5 JWT signing secret. Generate a long random value.
AUTH_SECRET="replace-with-a-long-random-secret"

# Public canonical HTTPS origin, with no trailing slash.
NEXT_PUBLIC_APP_URL="https://app.example.com"

# Optional: enables the existing Google Sheets synchronization.
GOOGLE_SPREADSHEET_ID=""

# Reserved for a future, separately approved Google Wallet provider adapter.
# Keep disabled until an issuer account, server-only secret manager, and
# production activation review are complete. Never commit a service-account key.
GOOGLE_WALLET_ENABLED="false"
GOOGLE_WALLET_ISSUER_ID=""
