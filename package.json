{
  "name": "loyalflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:financial-integrity": "tsx scripts/verify-financial-integrity.ts",
    "verify:local-db": "tsx scripts/verify-local-database.ts",
    "verify:local-promotions": "tsx scripts/verify-local-promotions.ts",
    "verify:local-reward-expiration": "tsx scripts/verify-local-reward-expiration.ts",
    "verify:local-referrals": "tsx scripts/verify-local-referrals.ts",
    "verify:local-staff-permissions": "tsx scripts/verify-local-staff-permissions.ts",
    "verify:local-multi-branch": "tsx scripts/verify-local-multi-branch.ts",
    "verify:local-customer-notes-tags": "tsx scripts/verify-local-customer-notes-tags.ts",
    "verify:local-bulk-customer-operations": "tsx scripts/verify-local-bulk-customer-operations.ts",
    "verify:local-offers": "tsx scripts/verify-local-offers.ts",
    "verify:local-business-profile-foundation": "tsx scripts/verify-local-business-profile-foundation.ts",
    "prepare:final-uat": "tsx scripts/prepare-final-uat-fixtures.ts",
    "cleanup:final-uat": "tsx scripts/prepare-final-uat-fixtures.ts",
    "create-admin": "tsx scripts/create-super-admin.ts",
    "sync-sheets": "tsx scripts/sync-google-sheets.ts",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@prisma/adapter-pg": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "type": "module",
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
